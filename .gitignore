# Secrets
.env

# Private project context (interview strategy / personal notes — never publish)
docs/*.private.md
handover.md
.claude/settings.local.json

# Data (copyrighted manuals / local assets — never redistribute)
data/*.pdf
data/*.png
data/*.jpg
# M5 vision captions + page renders: derived from the copyrighted manual
data/captions/
!data/.gitkeep

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/

# Local vector-store / build artifacts
*.sqlite
.cache/
outputs/

# OS / editor
.DS_Store
.idea/
.vscode/

# Raw eval run logs: contain full manual text (copyrighted corpus, same
# reason data/ is ignored). The .md reports carry no chunk text and ARE committed.
eval/results/*.json

# Superseded local run artifacts (pre-re-baseline)
eval/results/superseded/
